# Connection string do PostgreSQL (padrao: postgresql+asyncpg://appuser:apppass123@localhost:5432/app_db)
DATABASE_URL=postgresql+asyncpg://appuser:apppass123@localhost:5432/app_db

# Chave de API da Anthropic (obrigatorio quando usar agentes)
ANTHROPIC_API_KEY=sk-ant-...

# Intervalo em minutos entre coletas de eventos Kubernetes (padrao: 3)
EVENT_COLLECTION_INTERVAL_MINUTES=3

# Limite de chamadas de tools do agente de analise (padrao: 25)
AGENT_MAX_ITERATIONS=25

# URL do MCP Server Kubernetes (padrao: http://localhost:3001/mcp)
MCP_KUBERNETES_URL=http://localhost:3001/mcp

# Token do bot Discord para notificacoes (opcional - sem configurar, notificacoes ficam desabilitadas)
DISCORD_BOT_TOKEN=

# ID do canal Discord para envio de notificacoes (opcional)
DISCORD_CHANNEL_ID=

# URL base da interface web para links nas notificacoes (padrao: http://localhost:8000)
APP_BASE_URL=http://localhost:8000
